# CatCare UTM Backend — Environment Variables
# Copy this file to .env and fill in your values

# Server
NODE_ENV=production
PORT=10000

# PostgreSQL Database (Render)
DATABASE_HOST=dpg-xxxxx.oregon-postgres.render.com
DATABASE_PORT=5432
DATABASE_USER=catcare_admin
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=catcare_db

# JWT Authentication
JWT_SECRET=your_jwt_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# CORS — your frontend URL (no trailing slash)
CORS_ORIGIN=https://catcare-frontend-inky.vercel.app

# TG-1 Security — AES-256 key for encrypting volunteer_id and student_id
# Generate a fresh key with: openssl rand -hex 32
# NEVER commit the real value to Git — this placeholder will fail validation on purpose
ENCRYPTION_KEY=your_64_char_hex_key_here_run_openssl_rand_hex_32_to_generate
