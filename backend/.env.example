# CatCare UTM Backend — Environment Variables
# Copy this file to .env and update the values
# NEVER commit .env to git

NODE_ENV=development
PORT=10000

# Cloudinary — persistent file uploads (images stored in cloud)
# Option 1: Set all three individual vars
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Option 2: Set CLOUDINARY_URL (overrides individual vars)
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=catcare_utm

JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MED-03: Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=run_openssl_rand_hex_32_to_generate_this_value

# CRIT-4: Optional CSRF secret (falls back to JWT_SECRET if not set; must be ≥32 chars)
# Generate with: openssl rand -hex 32
CSRF_SECRET=

# MED-10: Optional — Logtail token for production log aggregation
LOGTAIL_TOKEN=

# Google Maps API key for map proxy endpoint
GOOGLE_MAPS_API_KEY=

# SMTP — for sending password reset and email verification emails
# If not set, reset URLs are logged to the console (development fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Frontend URL — used to construct email links (password reset, email verification)
FRONTEND_URL=http://localhost:3000
