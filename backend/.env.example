# CatCare UTM Backend — Environment Variables
# Copy this file to .env and update the values
# NEVER commit .env to git

NODE_ENV=development
PORT=10000

# Supabase — persistent file uploads (images stored in Supabase Storage)
# Free tier: 1GB storage, no credit card required
# Setup: https://supabase.com → Create project → Project Settings → API
# 1. Create a Supabase project at https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the Project URL → SUPABASE_URL
# 4. Copy the service_role key → SUPABASE_SERVICE_ROLE_KEY
# 5. Create a storage bucket named "uploads" in Supabase dashboard → Storage
# 6. Set the bucket to public (so images can be displayed)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=uploads

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=catcare_utm

JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# MED-03: Comma-separated list of allowed CORS origins
# CRITICAL for production: Must include your Vercel frontend URL, e.g.:
# CORS_ORIGIN=https://catcare-utm.vercel.app
# Multiple origins (comma-separated): https://catcare-utm.vercel.app,https://staging.vercel.app
CORS_ORIGIN=http://localhost:3000

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=run_openssl_rand_hex_32_to_generate_this_value

# CRIT-4: Optional CSRF secret (falls back to JWT_SECRET if not set; must be ≥32 chars)
# Generate with: openssl rand -hex 32
CSRF_SECRET=

# MED-10: Optional — Logtail token for production log aggregation
LOGTAIL_TOKEN=

# Google Maps API key for map proxy endpoint
GOOGLE_MAPS_API_KEY=

# SMTP — for sending password reset and email verification emails
# If not set, reset URLs are logged to the console (development fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Frontend URL — used to construct email links (password reset, email verification)
FRONTEND_URL=http://localhost:3000
