# CatCare UTM Backend — Environment Variables
# Copy this file to .env and update the values
# NEVER commit .env to git

NODE_ENV=development
PORT=10000

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=catcare_utm

JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here
JWT_EXPIRES_IN=7d

# MED-03: Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=run_openssl_rand_hex_32_to_generate_this_value

# CRIT-4: Optional CSRF secret (falls back to JWT_SECRET if not set; must be ≥32 chars)
# Generate with: openssl rand -hex 32
CSRF_SECRET=

# MED-10: Optional — Logtail token for production log aggregation
LOGTAIL_TOKEN=

# MED-5: Optional Cloudinary for persistent file uploads (falls back to local disk)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
