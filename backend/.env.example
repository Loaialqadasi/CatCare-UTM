# CatCare UTM Backend — Environment Variables
# Copy this file to .env and update the values.
# NEVER commit .env to git.
#
# Tip: generate secrets with `openssl rand -hex 32`

NODE_ENV=development
PORT=10000

# ─── Database (PostgreSQL) ──────────────────────────────────────────
# Option A (RECOMMENDED — Supabase / Neon / any cloud DB):
#   Set DATABASE_URL to the full connection string from your provider dashboard.
#   Supabase: Project Settings → Database → Connection string → URI format
#   Example (pooler — port 6543):
#     postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
#   Example (direct — port 5432, recommended for Render):
#     postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=

# Option B (local Postgres / Docker):
#   If DATABASE_URL is not set, the individual vars below are used instead.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=catcare_utm

# SSL cert verification:
#   - Leave unset (default) for Supabase POOLER connection (port 6543).
#     The pooler uses a self-signed cert, so verification is skipped.
#     The connection is still TLS-encrypted.
#   - Set to 'true' ONLY if using the DIRECT connection (port 5432),
#     which has a proper CA-signed certificate.
DB_SSL_REJECT_UNAUTHORIZED=

# ─── Auth secrets ───────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ENCRYPTION_KEY=run_openssl_rand_hex_32_to_generate_this_value
CSRF_SECRET=

# ─── CORS ───────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# CRITICAL for production: must include your Vercel frontend URL.
#   CORS_ORIGIN=https://catcare-frontend-inky.vercel.app
# Multiple origins:
#   CORS_ORIGIN=https://catcare-frontend-inky.vercel.app,https://staging.vercel.app
CORS_ORIGIN=http://localhost:3000

# Frontend URL — used to construct email links (password reset, verification)
FRONTEND_URL=http://localhost:3000

# ─── Supabase Storage (file uploads) ────────────────────────────────
# Free tier: 1GB storage, no credit card required.
# Setup: https://supabase.com → Create project → Project Settings → API
# 1. Copy the Project URL → SUPABASE_URL
# 2. Copy the service_role key → SUPABASE_SERVICE_ROLE_KEY
# 3. Create a storage bucket named "uploads" (or let the backend auto-create)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=uploads

# Public Supabase keys (also referenced by the frontend at build time)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Email (Nodemailer) ─────────────────────────────────────────────
# For password reset and email verification emails.
# If unset, reset URLs are logged to the console (dev fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CatCare UTM <noreply@utm.my>"

# ─── Optional ───────────────────────────────────────────────────────
# Logtail token for production log aggregation
LOGTAIL_TOKEN=

# Google Maps API key (alternative to OSM Nominatim for geocoding)
GOOGLE_MAPS_API_KEY=
