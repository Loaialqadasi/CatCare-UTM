# CatCare UTM Frontend — Environment Variables
# Copy this file to `.env.local` and fill in the values.

# ─── Option A (RECOMMENDED): Next.js rewrite proxy ───────────────────────
# Set BACKEND_URL to your backend's root URL (no /api suffix).
# The frontend proxies all /api/* requests through Next.js, so cookies are
# same-origin (no SameSite=None / third-party cookie issues). This is the
# correct setup for production (Vercel frontend + Render backend).
#
# In production (Vercel), set this as a server-side env var in the Vercel
# dashboard (NOT NEXT_PUBLIC_* — server-side only).
BACKEND_URL=http://localhost:10000

# ─── Option B (DEBUG ONLY): Direct cross-origin calls ────────────────────
# Uncomment to bypass the proxy and call the backend directly from the browser.
# This makes cookies cross-origin, which may be blocked by modern browsers
# (Chrome 120+, Safari, Firefox) as third-party cookies. Only use this for
# local debugging where you want to inspect raw network traffic to the backend.
# NEXT_PUBLIC_API_URL=http://localhost:10000/api
