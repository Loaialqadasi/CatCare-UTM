# CatCare UTM Frontend — Environment Variables
# Copy this file to .env.local and update the values
# CRIT-2: .env.local should NEVER be committed to git

# Backend API base URL (required)
# If deploying backend on Render:  https://catcare-backend.onrender.com/api
# If running backend locally:      http://localhost:10000/api
NEXT_PUBLIC_API_URL=http://localhost:10000/api

# Google Maps API key for campus map
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
