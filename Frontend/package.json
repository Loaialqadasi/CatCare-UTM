{
  "name": "catcare-utm-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "CatCare UTM — Campus Cat Management System frontend (Next.js 16 + React 19 + Tailwind 4 + shadcn/ui).",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
